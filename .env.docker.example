# Docker stack — copy to `.env` in repo root (used by docker compose + sidecar)
#   cp .env.docker.example .env

# Host port for the gateway (Stirling UI + /french-reader API)
FRENCH_READER_HTTP_PORT=8080

# LLM (optional — users can also paste keys in Settings UI)
FRENCH_READER_LLM_API_KEY=
FRENCH_READER_LLM_BASE_URL=https://api.moonshot.ai/v1
FRENCH_READER_LLM_MODEL=moonshot-v1-32k
