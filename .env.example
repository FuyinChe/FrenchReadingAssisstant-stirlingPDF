# French Reader local secrets — copy to `.env` and fill in values.
#   cp .env.example .env
#
# Kimi / Moonshot (OpenAI-compatible) — default provider in Settings UI
# - Hong Kong / overseas: https://api.moonshot.ai/v1
# - Mainland China:       https://api.moonshot.cn/v1  (choose "Kimi 国内版" in Settings)
# Get API key: https://platform.moonshot.ai/
# Other providers (OpenAI, DeepSeek, 智谱, OpenRouter, custom) can be selected in Settings.

FRENCH_READER_LLM_API_KEY=
FRENCH_READER_LLM_BASE_URL=https://api.moonshot.ai/v1
FRENCH_READER_LLM_MODEL=moonshot-v1-32k

# Optional overrides
# FRENCH_READER_ENABLED=true
# FRENCH_READER_TTS_MAX_CHARS=5000
# FRENCH_READER_AI_MAX_CHARS=5000
